# Python
__pycache__/
*.pyc
*.egg-info/
.venv/
venv/

# Node
node_modules/
dist/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Docker
.env

# Runtime
*.log
celerybeat-schedule*
celerybeat.pid

# System
.DS_Store
Thumbs.db

# Sisyphus internal
.sisyphus/

# Dev script output
backups/

# Production data dumps - never commit (multi-GB binary blobs)
# data_import/ directory itself stays tracked via README.md
data_import/*.sqlite
data_import/*.sqlite-journal
data_import/*.sqlite-wal
data_import/*.sqlite-shm
data_import/*.sqlite.gz
data_import/*.sql
data_import/*.sql.gz
data_import/*.dump
data_import/*.xlsx
backend/data_import/

# opencode/Sisyphus session state
.omo/

# Legacy/archived code - track source only, exclude nested repos, deps, and large binary dumps
legacy/postgres_backup.sql
legacy/*/.git/
legacy/*/node_modules/
legacy/*/dist/
legacy/*/__pycache__/
legacy/*/*.pyc

# Playwright MCP browser session artifacts
.playwright-mcp/
