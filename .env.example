# ============================================================
# MolluscAI Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=mollusc
POSTGRES_PASSWORD=mollusc_dev
POSTGRES_DB=molluscai
POSTGRES_PORT=5433

# --- Redis ---
REDIS_PORT=6380

# --- MinIO Object Storage ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003

# --- JWT Authentication ---
JWT_SECRET_KEY=replace-me-with-a-64-char-random-secret-string
JWT_REFRESH_SECRET_KEY=replace-me-with-another-64-char-random-secret-string

# --- Encryption (AES key for encrypting model API keys in DB) ---
ENCRYPTION_KEY=replace-me-with-a-32-byte-hex-encoded-key

# --- External API Keys ---
# DeepSeek (LLM generation + metadata extraction)
DEEPSEEK_API_KEY=
# SiliconFlow (Qwen3-VL-Embedding)
SILICONFLOW_API_KEY=
# Zhipu AI (GLM-OCR)
ZHIPU_API_KEY=

# --- MolluscaBase API (taxon verification) ---
MOLLUSCABASE_API_URL=https://api.molluscabase.org

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Backend ---
BACKEND_PORT=8000

# --- Frontend ---
FRONTEND_PORT=3000
